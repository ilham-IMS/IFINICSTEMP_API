{"name":"IFinancing360","settings":"{\"settings\":\"{\\r\\n    \\\"terminal.integrated.defaultProfile.windows\\\": \\\"Command Prompt\\\",\\r\\n    \\\"editor.minimap.enabled\\\": false,\\r\\n    \\\"workbench.iconTheme\\\": \\\"material-icon-theme\\\",\\r\\n    \\\"editor.fontFamily\\\": \\\"Fira Code\\\",\\r\\n    \\\"editor.fontLigatures\\\": true,\\r\\n    \\\"javascript.updateImportsOnFileMove.enabled\\\": \\\"always\\\",\\r\\n    \\\"typescript.updateImportsOnFileMove.enabled\\\": \\\"always\\\",\\r\\n    \\\"[html]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"vscode.html-language-features\\\"\\r\\n    },\\r\\n    \\\"prettier.tabWidth\\\": 4,\\r\\n    \\\"[typescript]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"vscode.typescript-language-features\\\"\\r\\n    },\\r\\n    \\\"editor.formatOnSave\\\": true,\\r\\n    \\\"editor.tabSize\\\": 2,\\r\\n    \\\"editor.wordWrap\\\": \\\"on\\\",\\r\\n    \\\"editor.wrappingStrategy\\\": \\\"advanced\\\",\\r\\n    \\\"workbench.editor.pinnedTabsOnSeparateRow\\\": true,\\r\\n    \\\"window.zoomLevel\\\": 1,\\r\\n    \\\"dotnetAcquisitionExtension.existingDotnetPath\\\": [\\r\\n        {\\r\\n            \\\"extensionID\\\": \\\"ms-dotnettools.csdevkit\\\",\\r\\n            \\\"path\\\": \\\"C:\\\\\\\\Program Files\\\\\\\\dotnet\\\\\\\\dotnet.exe\\\"\\r\\n        }\\r\\n    ],\\r\\n    \\\"extensions.autoUpdate\\\": false,\\r\\n    \\\"files.exclude\\\": {\\r\\n        \\\"__MACOSX\\\": true,\\r\\n        \\\"**/bin\\\": true,\\r\\n        \\\"**/obj\\\": true\\r\\n    },\\r\\n    \\\"files.associations\\\": {\\r\\n        \\\"*.cshtml\\\": \\\"html\\\"\\r\\n    },\\r\\n    \\\"git.autofetch\\\": true,\\r\\n    \\\"workbench.colorTheme\\\": \\\"One Dark Pro Darker\\\",\\r\\n    \\\"workbench.startupEditor\\\": \\\"none\\\",\\r\\n    \\\"editor.detectIndentation\\\": false,\\r\\n    \\\"git.enableSmartCommit\\\": true\\r\\n}\\r\\n\"}","snippets":"{\"snippets\":{\"csharp.json\":\"{\\n\\t// Place your snippets for csharp here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t\\\"Print to console\\\": {\\n\\t\\t\\\"prefix\\\": \\\"begin-transaction\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"using (var transaction = _repo.BeginTransaction())\\\",\\n\\t\\t\\t\\\"{\\\",\\n\\t\\t\\t\\\"\\ttry\\\",\\n\\t\\t\\t\\\"\\t{\\\",\\n\\t\\t\\t\\\"\\t\\ttransaction.Commit();\\\",\\n\\t\\t\\t\\\"\\t}\\\",\\n\\t\\t\\t\\\"\\tcatch (Exception)\\\",\\n\\t\\t\\t\\\"\\t{\\\",\\n\\t\\t\\t\\\"\\t\\ttransaction.Rollback();\\\",\\n\\t\\t\\t\\\"\\t\\tthrow;\\\",\\n\\t\\t\\t\\\"\\t}\\\",\\n\\t\\t\\t\\\"}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Using Transaction Scope\\\"\\n\\t}\\n}\",\"html.json\":\"{\\n\\t\\\"Toolbar Container\\\": {\\n\\t\\t\\\"prefix\\\": \\\"toolbar-container\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"<!-- #region Toolbar -->\\\",\\n\\t\\t\\t\\\"<div class=\\\\\\\"toolbar d-flex justify-content-between\\\\\\\">\\\",\\n\\t\\t\\t\\\"\\t\\t<div>$1\\\",\\n\\t\\t\\t\\\"\\t\\t\\t<button type=\\\\\\\"button\\\\\\\" class=\\\\\\\"btn btn-round btn-danger\\\\\\\" (click)=\\\\\\\"btnBack()\\\\\\\">Back</button>\\\",\\n\\t\\t\\t\\\"\\t\\t</div>\\\",\\n\\t\\t\\t\\\"\\t\\t<div>$2</div>\\\",\\n\\t\\t\\t\\\"</div>\\\"\\n\\t\\t\\t\\\"<!-- #endregionToolbar -->\\\",\\n\\t\\t\\t\\\"$999\\\"\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Toolbar Container\\\",\\n\\t\\t\\\"scope\\\": \\\"html\\\"\\n\\t},\\n\\n\\t\\\"List Page Container\\\":{\\n\\t\\t\\\"prefix\\\": \\\"list-page-container\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"<router-outlet></router-outlet>\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"<div id=\\\\\\\"hideMainPanel\\\\